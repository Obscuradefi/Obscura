# Arc Testnet RPC (default works without override)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Deployer wallet — get testnet USDC for gas at https://faucet.circle.com (Arc Testnet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# WalletConnect (frontend) — create at https://cloud.reown.com (formerly cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Optional: override the default Arc Testnet RPC the dapp uses
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# Optional: AI intent parser. Without this, NL parsing falls back to local regex.
VITE_JATEVO_API_KEY=

# RFQ maker (browser-side demo signer). Production: replace with VITE_RFQ_API_URL.
# Must match the wallet that the deploy script set as the initial RFQ maker.
VITE_RFQ_MAKER_PRIVATE_KEY=

# Optional: remote RFQ server URL (POST tokenIn/tokenOut/amountIn -> SignedQuote[])
VITE_RFQ_API_URL=

# Trade size (USD) above which the smart router engages RFQ. Below this,
# every swap goes straight to the AMM (Pyth-priced) for low-latency execution.
# Default 1000 for testnet demos. Production should be ~100000.
VITE_RFQ_MIN_USD=1000

# Optional: skip Pyth Hermes calls and use mock prices for the off-chain feed
VITE_DISABLE_PYTH=

# ----- Circle Modular Wallets (passkey + gasless USDC) -----
# Create a Client Key + Domain at https://console.circle.com → Wallets → Modular
# https://developers.circle.com/wallets/modular/console-setup
#
# When NOT set, the Circle Wallet button shows a "(not configured)" tooltip
# and the dapp falls back to RainbowKit/MetaMask only.
VITE_CIRCLE_CLIENT_KEY=
VITE_CIRCLE_CLIENT_URL=
VITE_CIRCLE_PASSKEY_NAME=obscura-agent
VITE_JATEVO_BASE_URL=https://jatevo.id/api/open/v1/inference
VITE_JATEVO_MODEL=glm-4.7
